# ============================================================
#  HighView AI Companion — Environment Variables
#  Copy to .env for local dev. Set in Vercel dashboard for production.
#  NEVER commit .env to git.
# ============================================================


# ────────────────────────────────────────────────────────────
#  API KEYS  (secret — backend only, never exposed to browser)
# ────────────────────────────────────────────────────────────

# Anthropic — required for all AI chat + session summarisation
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI — optional, only for semantic memory embeddings (pgvector)
# Leave blank to silently skip embeddings
OPENAI_API_KEY=sk-proj-...

# Resend — required for password reset emails
RESEND_API_KEY=re_...

# Supabase — required for all DB operations (server-side only)
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_ANON_KEY=eyJ...


# ────────────────────────────────────────────────────────────
#  AUTH
# ────────────────────────────────────────────────────────────

# JWT signing secret — must be long, random, and secret
# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string

# Token lifetime — e.g. 30d, 7d, 24h
JWT_EXPIRY=30d


# ────────────────────────────────────────────────────────────
#  DEPLOYMENT  (change per environment)
# ────────────────────────────────────────────────────────────

# Public URL of the deployed app — used to build password reset links
APP_URL=https://ai-companion-frontend-iota.vercel.app

# Sender address shown in password reset emails
# Must be a verified domain in your Resend account
EMAIL_FROM=HighView AI Coach <onboarding@resend.dev>


# ────────────────────────────────────────────────────────────
#  FRONTEND  (VITE_ prefix = exposed to the browser bundle)
# ────────────────────────────────────────────────────────────

# Base URL for API calls from the frontend
# Leave blank on Vercel (same-origin). Set for local dev:
VITE_API_URL=http://localhost:3000


# ────────────────────────────────────────────────────────────
#  AI MODEL SELECTION  (swap without touching code)
# ────────────────────────────────────────────────────────────

# Model for live streaming chat responses
ANTHROPIC_CHAT_MODEL=claude-opus-4-7

# Model for post-session summarisation and memory extraction (faster/cheaper)
ANTHROPIC_EXTRACT_MODEL=claude-haiku-4-5

# OpenAI model for generating session embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-small


# ────────────────────────────────────────────────────────────
#  COACHING BEHAVIOUR  (tune defaults without touching code)
# ────────────────────────────────────────────────────────────

# Default nudge count before the AI shows an example answer (0–5)
DEFAULT_NUDGE_LIMIT=2

# Max tokens for the live chat stream response
CHAT_MAX_TOKENS=2048

# Max tokens for session summary generation
SUMMARY_MAX_TOKENS=512

# Max tokens for skill memory extraction
EXTRACTION_MAX_TOKENS=512

# Max tokens for skill evidence (why-score) generation
EVIDENCE_MAX_TOKENS=400

# Minimum messages in a session before summarisation runs
MIN_MESSAGES_TO_SUMMARIZE=4

# How many days a weekly check-in stays fresh and gets injected into AI context
CHECKIN_WINDOW_DAYS=7
